{
  "name": "@blenx-dev/ui",
  "version": "0.0.4",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*",
      "default": "./src/components/*"
    },
    "./utils/*": {
      "types": "./src/utils/*",
      "default": "./src/utils/*"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@blenx-dev/theme": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "^8.21.3",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "clsx": "^2.1.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
