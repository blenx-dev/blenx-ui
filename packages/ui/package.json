  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@stylexjs/unplugin": "^0.18.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
