{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "composite": false,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/src",
    "rootDir": "src",
    "noEmitOnError": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
