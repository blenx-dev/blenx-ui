{
  "name": "blenx-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo dev",
    "check": "oxlint && oxfmt --write",
    "clean": "rimraf --glob node_modules dist build .turbo **/node_modules **/dist **/build && turbo -F clean",
    "generate:registry": "tsx scripts/generate-docs-manifest.ts",
    "generate:api": "tsx scripts/generate-api-meta.ts",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:release": "changeset publish",
    "publish:all": "pnpm -r --filter './packages/*' publish --access public"
  },
  "dependencies": {
    "@blenx-dev/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@blenx-dev/config": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@types/node": "catalog:",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "rimraf": "^6.1.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
