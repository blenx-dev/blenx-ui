{
  "name": "blenx-ui",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "check": "oxlint && oxfmt --write",
    "registry:gen": "ts-node packages/registry/build.ts",
    "registry:build": "bun registry:gen && shadcn build packages/registry/registry.json --output apps/web/public/reg && bun packages/registry/clean.ts",
    "registry:dev": "bun registry:build && serve packages/registry/public/r -p 3001"
  },
  "dependencies": {
    "@blenx-ui/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@blenx-ui/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "shadcn": "^4.11.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
